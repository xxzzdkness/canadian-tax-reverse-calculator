{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "target": "ES2020"
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "lib/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "db",
    "examples",
    "scripts",
    "tests",
    "worker"
  ]
}
